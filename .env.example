# --- Backend Configuration ---
DEBUG=false
# Secret key for JWT/HMAC signing (replaces Telegram Bot Token as primary secret)
AUTH_SECRET=your_auth_secret_here

# Google OAuth Client ID (from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Google Gemini API Key (from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated User IDs of users who can access the admin panel (Google 'sub' claim)
ADMIN_USER_IDS=518383100
VITE_ADMIN_USER_IDS=518383100

# --- Telegram (Optional Notifications) ---
# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=apitoken
# Telegram Group/Channel ID where notifications will be sent
TELEGRAM_GROUP_ID=-5197772476

# --- Database Configuration (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aphantasia
DB_USER=postgres
DB_PASS=postgres

# --- Frontend Configuration ---
# The URL where the backend is accessible from the browser
VITE_API_URL=http://localhost:8000
VITE_PORT=3000
VITE_HOST=0.0.0.0
VITE_ALLOWED_HOSTS=localhost
BACKEND_PORT=8000
PROD_PORT=80

# Site Metadata
VITE_SITE_NAME=NeuroProfile
VITE_BASE_URL=https://np42.dev
